# Transcription backend to use.
# Options: 'whisper' (default), 'faster-whisper', 'elevenlabs', 'google', 'assemblyai',
#          'whisper-diarization', 'faster-whisper-diarization'
#
# LOCAL BACKENDS (free, run on your machine):
# - whisper: OpenAI Whisper, ~1-2 min per hour
#   Install: pip install openai-whisper
#
# - faster-whisper: Optimized Whisper, ~15-30 sec per hour (recommended local)
#   Install: pip install faster-whisper
#
# - whisper-diarization: Whisper + speaker identification
#   Install: pip install openai-whisper pyannote.audio
#   Note: First run requires HuggingFace token
#
# - faster-whisper-diarization: Faster-Whisper + speaker identification
#   Install: pip install faster-whisper pyannote.audio
#   Note: First run requires HuggingFace token
#
# CLOUD BACKENDS (paid, faster):
# - elevenlabs: Word-level timestamps + speaker diarization, ~$5-99/month
#   Install: pip install requests
#   Get key: https://elevenlabs.io (free tier: 10k chars/month)
#
# - google: Google Cloud Speech-to-Text, ~$0.044 per 15 seconds
#   Install: pip install google-cloud-speech
#   Get credentials: https://console.cloud.google.com/iam-admin/serviceaccounts
#   Note: Requires GOOGLE_APPLICATION_CREDENTIALS env var
#
# - assemblyai: AssemblyAI, ~$0.0001 per second (~$0.36/hour)
#   Install: pip install assemblyai
#   Get key: https://www.assemblyai.com (free tier: $50 credits)
#
# Default is 'whisper' (local, free, no API key needed).
TRANSCRIBER_BACKEND=whisper

# API keys (only needed for cloud backends)
ELEVENLABS_API_KEY=
ASSEMBLYAI_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json (env var, not .env)
